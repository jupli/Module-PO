generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  description String?
  quantity    Float    @default(0)
  price       Float    @default(0)
  unit        String   @default("pcs")
  category    String?
  packet      String?  // Field baru untuk menyimpan info Paket (e.g. "PAKET KERINGAN", "PAKET BUMIL")
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  goodsReceiptItems  GoodsReceiptItem[]
  recipeItems        RecipeItem[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  address   String?
  email     String?
  phone     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  products       Product[]
}

enum POStatus {
  PENDING
  APPROVED
  KIRIM
  REJECTED
  RECEIVED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum MovementType {
  IN
  OUT
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  poNumber    String   @unique
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  date        DateTime @default(now())
  status      POStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  totalAmount Float    @default(0)
  notes       String?
  documentPath String? // Path to archived PDF
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items         PurchaseOrderItem[]
  goodsReceipt  GoodsReceipt?
  payments      PurchasePayment[]
}

model PurchasePayment {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  amount          Float
  paymentDate     DateTime      @default(now())
  method          String        // CASH, TRANSFER, CREDIT
  reference       String?       // Transfer ID / Check No
  notes           String?
  proofImage      String?       // Path/Url to proof image
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model GoodsReceipt {
  id          String   @id @default(cuid())
  poId        String   @unique
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  doNumber    String
  receivedAt  DateTime
  receiver    String?
  receiverSign String? @db.LongText // Base64 signature
  courier     String?
  courierSign String? @db.LongText // Base64 signature
  condition   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id              String       @id @default(cuid())
  goodsReceiptId  String
  goodsReceipt    GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  quantity        Float
  quantityRejected Float      @default(0)
  condition       String?
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Float
  unit            String?
  price           Float
  notes           String?
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  type        MovementType
  quantity    Float
  reference   String?  // PO Number or "MANUAL"
  notes       String?
  createdAt   DateTime @default(now())
}

model Recipe {
  id          String       @id @default(cuid())
  name        String       // Removed @unique to allow multiple batches of same menu
  requestId   String?      // To prevent duplicate batches from same request
  purchaseDate DateTime?   // Date from Purchase Request
  description String?
  defaultPortion Int       @default(1)
  ingredients RecipeItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model RecipeItem {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float   // Quantity required for the recipe
  unit      String  // Unit for the recipe (e.g., "gram", "ml")
  notes     String? // e.g., "±150 gram/porsi matang"
}

model DeliveryQueue {
  id        String   @id @default(cuid())
  menuName  String
  quantity  Int
  cookDate  DateTime @default(now())
  status    String   // PENDING_QC, READY_TO_SHIP, SHIPPED, REJECTED
  
  // QC Details
  qcBy      String?
  qcDate    DateTime?
  qcStatus  String? // PASS, REJECT
  qcNotes   String?
  photoUrl  String? // Path to QC Photo
  
  // Shipping Details
  shippedAt     DateTime?
  senderName    String?
  destination   String?
  receiverName  String?
  arrivalTime   DateTime?
  senderSign    String? @db.LongText // Base64 or URL
  receiverSign  String? @db.LongText // Base64 or URL
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryForm {
  id              String   @id @default(cuid())
  deliveryQueueId String
  formTitle       String   @map("FormTitle")
  courierName     String
  senderName      String?
  pickupAt        DateTime
  destination     String
  portions        Int
  receiverName    String?  @map("ReceiverName")
  photoUrl        String?
  senderSign      String?  @db.LongText
  courierSign     String?  @db.LongText
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([deliveryQueueId])
  @@map("delivery_forms_dcms_app")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseRequest {
  id        String   @id @default(cuid())
  requestDate DateTime // Tanggal permintaan (dari Excel)
  status    RequestStatus @default(PENDING)
  notes     String?
  purchasingSign String? @db.LongText // Base64 signature
  managerSign    String? @db.LongText // Base64 signature
  rejectionReason String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  items     PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id                String          @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  
  itemName          String          // Nama bahan dari Excel
  category          String?         // Kategori Menu (dari Excel)
  portion           String?         // Porsi Besar / Kecil
  quantity          Float
  unit              String
  price             Float           @default(0) // Harga satuan
  notes             String?
  
  status            ItemStatus      @default(PENDING)
}

model Beneficiary {
  id        String   @id @default(cuid())
  name      String   // Nama Sekolah / Penerima Manfaat
  total     Int      // Jumlah Siswa + GTK
  portionSmall Int   // Porsi Kecil
  portionLarge Int   // Porsi Besar
  date      DateTime // Tanggal Data (biasanya per hari / per sheet)
  category  String?  // PM PAKET BASAH / PM PAKET KERING / etc.
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum ItemStatus {
  PENDING
  PO_CREATED
  REJECTED
}
