{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/migration/layout,_N_T_/migration/page,_N_T_/migration"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/migration/__PAGE__",
    "/migration",
    "/_index",
    "/_head"
  ]
}